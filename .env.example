# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.
# The application refuses to start against any non-paper Alpaca endpoint.

# --- Alpaca paper trading (paper endpoint only) ---
ALPACA_API_KEY_ID=PK_your_paper_key_id_here
ALPACA_API_SECRET_KEY=your_paper_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_DATA_URL=https://data.alpaca.markets/v2

# --- LLM provider (OpenAI) ---
# Dev defaults favor cheap models. Override per-track or per-agent later.
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL_DEFAULT=gpt-5-nano
OPENAI_MODEL_JUDGE=gpt-5-mini

# --- Database ---
DATABASE_URL=postgresql+psycopg://stockripper:stockripper@localhost:5432/stockripper

# --- Runtime ---
STOCKRIPPER_ENV=local
STOCKRIPPER_TIMEZONE=America/New_York
